# Bot Configuration
BOT_TOKEN=BEEFBD0ADXAMRWXJJJPUPENMFDVPVJOTIQCCSYFQGEHHBSNRGDGGZSNJAKNXQCLW
TIMEZONE=Asia/Tehran

# Inline webhook URL — must be the HTTPS address of this app + /webhook
# Example: https://your-app.paas.ir/webhook
# Without this, inline keypad button clicks will NOT work.
RUBIKA_INLINE_WEBHOOK_URL=https://your-app.paas.ir/webhook

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/rubifo

# Payment Gateway
ZARINPAL_MERCHANT_ID=your_zarinpal_merchant_id

# Admin Panel
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=your_bcrypt_hash_here
JWT_SECRET=your_jwt_secret_key_here

# Logging
LOG_FILE=rubifo.log
LOG_LEVEL=INFO

# Trial Configuration
TRIAL_DURATION_HOURS=48
TRIAL_REMINDER_HOURS=24

# Rubika User Session (for reading channel posts)
USER_SESSION_NAME=rubifo_user
CHANNEL_POLL_INTERVAL=60

# API Rate Limiting
API_RATE_LIMIT_DELAY=0.5

# Schedule Check
SCHEDULE_CHECK_INTERVAL=30
