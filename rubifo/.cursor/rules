## 10. Common Patterns

### Async Database Query
```python
async def get_user_by_id(user_id: int) -> Optional[User]:
    """Fetch user from database."""
    async with db.transaction():
        result = await db.fetchrow(
            "SELECT * FROM users WHERE id = $1",
            user_id
        )
        return User(**result) if result else None
```

### Service Layer Pattern
```python
class UserService:
    def __init__(self, db):
        self.db = db

    async def create_user(self, user_id: int, username: str) -> User:
        """Create new user."""
        await self.db.execute(
            "INSERT INTO users (user_id, username) VALUES ($1, $2)",
            user_id, username
        )
        return await self.get_user(user_id)
```

### Bot Command Pattern
```python
@bot.on_command("/start")
async def handle_start(user_id: int, message: str):
    """Handle /start command."""
    user_service = UserService(db)
    user = await user_service.get_or_create(user_id)

    if user.trial_active:
        msg = "Welcome! You have 48h trial."
    else:
        msg = "Welcome! Trial expired."

    await bot.send_message(user_id, msg)
```

### Error Handling Pattern
```python
async def forward_message(post_id: int, target: int) -> bool:
    """Forward message with error handling."""
    try:
        message = await get_message(post_id)
        await send_message(target, message)
        return True
    except RubikaAPIError as e:
        logger.error(f"API error: {e}")
        await handle_retry()
        return False
    except Exception as e:
        logger.error(f"Unexpected error: {e}")
        return False
```

---

## 11. FastAPI Routes Pattern

```python
from fastapi import FastAPI, Depends, HTTPException
from src.admin.auth import verify_token

app = FastAPI()

@app.get("/admin/users")
async def list_users(token: str = Depends(verify_token)):
    """List all users."""
    users = await db.fetch("SELECT * FROM users")
    return {"users": users}

@app.post("/admin/users/{user_id}/message")
async def send_message(user_id: int, text: str, token: str = Depends(verify_token)):
    """Send message to user."""
    await bot.send_message(user_id, text)
    return {"status": "sent"}
```

---

## 12. Database Migrations

When adding tables:

```sql
-- migrations/001_init_schema.sql

CREATE TABLE users (
    id SERIAL PRIMARY KEY,
    user_id BIGINT UNIQUE NOT NULL,
    username VARCHAR(255),
    trial_start_at TIMESTAMP DEFAULT NOW(),
    trial_end_at TIMESTAMP,
    is_trial_active BOOLEAN DEFAULT true,
    created_at TIMESTAMP DEFAULT NOW(),
    updated_at TIMESTAMP DEFAULT NOW()
);

CREATE INDEX idx_users_user_id ON users(user_id);
```

